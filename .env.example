# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/resend
AUTH_SECRET=            # openssl rand -base64 32
AUTH_RESEND_KEY=        # Resend API key (magic links + notifications)
ENCRYPTION_KEY=         # 32-byte hex, encrypts DKIM private keys at rest (openssl rand -hex 32)
CRON_SECRET=            # bearer token for /api/cron/verify

# Optional: verification timings (ms), defaults shown
# PENDING_RECHECK_MS=60000
# SUCCESS_RECHECK_MS=86400000
# GRACE_PERIOD_MS=86400000
# GRACE_PERIOD_WARNING_MS=3600000
# VERIFICATION_WINDOW_MS=172800000
# NOTIFICATIONS_FROM=Inkwell <notifications@example.com>

# Optional: mock DNS console at /mocks. Never set in production.
# ENABLE_MOCK=true
